{
  "name": "opencode-cross-session-memory",
  "version": "1.0.0",
  "description": "Cross-session memory plugin for opencode - Persistent memory across conversations",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tui": {
      "import": "./dist/tui.js",
      "types": "./dist/tui.d.ts"
    }
  },
  "tui": "dist/tui.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "npx tsx --test test/*.test.ts",
    "verify": "npm run build && npm run typecheck && npx tsx --test test/*.test.ts",
    "benchmark:long-session": "npx tsx src/benchmark.ts"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.17.0",
    "pg": "^8.13.0",
    "pgvector": "^0.3.0"
  },
  "peerDependencies": {
    "solid-js": ">=1.0.0",
    "@opentui/solid": ">=0.1.0",
    "@opentui/core": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@opentui/solid": { "optional": true },
    "@opentui/core": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "overrides": {
    "@opencode-ai/plugin": "1.17.0"
  }
}
